{
  "region": "ap-northeast-1",
  "cluster_name": "xolis-lab",
  "sandbox_nodegroup": "xolis-sandbox",
  "sandbox_node_selector": "xolis.io/kata-ready=true",
  "sandbox_min_size": 0,
  "sandbox_desired_size": 1,
  "sandbox_max_size": 1,
  "tofu_directory": "infra/aws/minimal",
  "bootstrap_manifests": [
    "deploy/bootstrap/kata-runtime.yaml",
    "deploy/bootstrap/agent-sandbox.yaml"
  ],
  "test_manifest": "deploy/tests/smoke-sandbox.yaml",
  "ready_command": [
    "kubectl",
    "wait",
    "--namespace",
    "xolis-system",
    "--for=condition=Ready",
    "sandbox/smoke",
    "--timeout=10m"
  ],
  "artifact_directory": "artifacts/aws-lab",
  "node_ready_timeout_seconds": 900,
  "node_stop_timeout_seconds": 900
}
